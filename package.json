{
  "dependencies": {
    "cypress": "^15.6.0"
  },
  "devDependencies": {
    "cypress-mochawesome-reporter": "^4.0.2",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "dotenv": "^17.2.3"
  },
 "scripts": {
  "cy:run": "cypress run",
  "report:merge": "mochawesome-merge cypress/results/*.json > mochawesome.json",
  "report:generate": "marge mochawesome.json -f report -o cypress/reports",
  "test:report": "npm run cy:run && npm run report:merge && npm run report:generate"
}


}
